{
  "name": "mindful-block-monorepo",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "description": "Hệ sinh thái cai nghiện kỹ thuật số đa nền tảng",
  "workspaces": [
    "apps/*",
    "shared/*",
    "backend/*"
  ],
  "scripts": {
    "pc:dev": "pnpm --filter @mindful-block/pc tauri dev",
    "pc:build": "pnpm --filter @mindful-block/pc tauri build",
    "functions:build": "pnpm --filter @mindful-block/functions build",
    "mobile:dev": "pnpm --filter mobile dev",
    "backend:deploy": "cd backend/firebase && firebase deploy"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "pnpm": {
    "overrides": {
      "@firebase/app": "0.10.14",
      "@firebase/component": "0.6.9"
    }
  }
}
